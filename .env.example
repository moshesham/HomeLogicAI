ANTHROPIC_API_KEY=sk-ant-...          # Required for AI features
DATABASE_URL=sqlite:///./data/homelogicai.db # Database connection URL (SQLite in development)
STORAGE_PATH=./data/projects          # Local path for project files
SECRET_KEY=change-me-in-production    # JWT signing secret key
SCRAPER_SERVICE_URL=http://scraper:8001 # Internal scraper service base URL
SCRAPE_CACHE_TTL=86400                # Scrape cache TTL in seconds (24h)
MAX_COMPARE_PRODUCTS=4                # Maximum number of products in comparison view
LOG_LEVEL=INFO                        # Application log verbosity
CORS_ORIGINS=http://localhost:3000    # Comma-separated allowed CORS origins
ACCESS_TOKEN_EXPIRE_MINUTES=10080     # Access token expiry in minutes (7 days)
